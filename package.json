{
  "name": "@bounded-systems/fs",
  "version": "0.2.0",
  "description": "Filesystem capability seam; the one allowed filesystem-access point with an injectable FileSystem",
  "bounded": {
    "tagline": "Filesystem capability seam; the one allowed filesystem-access point with an injectable FileSystem",
    "kind": "door",
    "facet": "verb",
    "role": "capability-seam",
    "domain": "filesystem"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bounded-systems/fs.git"
  },
  "homepage": "https://github.com/bounded-systems/fs#readme",
  "bugs": {
    "url": "https://github.com/bounded-systems/fs/issues"
  },
  "keywords": [
    "filesystem",
    "capability",
    "seam",
    "injectable",
    "fs"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
